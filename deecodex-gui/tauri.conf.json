{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DEX AI Preview",
  "version": "3.3.8-preview.12",
  "identifier": "com.deecodex.app.preview",
  "mainBinaryName": "dex-ai-preview",
  "build": {
    "frontendDist": "gui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DEX AI Preview",
        "width": 1000,
        "height": 650,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": false,
    "resources": [
      "../deecodex-plugins/plugins/deecodex-weixin",
      "../deecodex-plugins/templates/node-tool",
      "../deecodex-plugins/templates/node-automation",
      "../deecodex-plugins/templates/python-datasource"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
