{
  "id": "example-node-tool",
  "name": "Example Node Tool",
  "version": "1.0.0",
  "description": "Node 工具插件模板",
  "author": "DEX AI",
  "kind": "tool",
  "tags": ["template", "node", "dex-tool"],
  "entry": {
    "runtime": "node",
    "script": "index.js",
    "args": []
