  "permissions": ["fs.read", "fs.write"],
  "config_schema": {
    "type": "object",
    "properties": {
      "message": {
        "type": "string",
        "default": "ready",
        "description": "状态消息"
      }
    }
  },
  "min_deecodex_version": "0.1.0"
