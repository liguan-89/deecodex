# deecodex 环境变量配置模板
# 复制为 .env 后修改

# === DeepSeek 配置 ===

# DeepSeek API 地址
DEECODEX_UPSTREAM=https://api.deepseek.com/v1

# DeepSeek API Key（必填）
# 登录 https://platform.deepseek.com → API Keys 获取
DEECODEX_API_KEY=sk-your-deepseek-api-key-here

# 本地客户端访问 deecodex 的 Bearer Token
# 留空可关闭本地鉴权；共享或被代理暴露时建议单独设置。
DEECODEX_CLIENT_API_KEY=relay-local-client-token

# 本地 hosted prompts registry 目录
DEECODEX_PROMPTS_DIR=prompts

# 监听端口
DEECODEX_PORT=4446

# 模型名映射（JSON 格式）
# Codex 硬编码的模型名 → DeepSeek 实际模型名
DEECODEX_MODEL_MAP='{"GPT-5.5":"deepseek-v4-pro","gpt-5.5":"deepseek-v4-pro","gpt-5.4":"deepseek-v4-flash","gpt-5.4-mini":"deepseek-v4-flash","codex-auto-review":"deepseek-v4-flash"}'

# 中文思考提示（开启后自动注入"请用中文思考"系统提示）
# DEECODEX_CHINESE_THINKING=true

# 日志级别
RUST_LOG=deecodex=info


# === 多模态视觉路由（可选）===
# 不配置则图片自动丢弃，纯文本正常工作
# 获取 Key：https://platform.minimaxi.com → API Keys

# CODEX_RELAY_VISION_UPSTREAM=https://api.minimaxi.com
# CODEX_RELAY_VISION_API_KEY=sk-your-minimax-api-key-here
# CODEX_RELAY_VISION_MODEL=MiniMax-M1
# CODEX_RELAY_VISION_ENDPOINT=v1/coding_plan/vlm
